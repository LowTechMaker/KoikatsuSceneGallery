<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="KoikatsuSceneGallery.Pages.ImportPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:KoikatsuSceneGallery.Models"
    xmlns:vm="using:KoikatsuSceneGallery.ViewModels"
    mc:Ignorable="d"
    AllowDrop="True"
    DragOver="Page_DragOver"
    Drop="Page_Drop">

    <Page.Resources>
        <DataTemplate x:Key="AuthorPickerItemTemplate" x:DataType="vm:SelectableAuthor">
            <Grid Padding="4,6" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <FontIcon FontSize="14" Glyph="&#xE77B;"
                          VerticalAlignment="Center"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <StackPanel Grid.Column="1" Spacing="0" VerticalAlignment="Center">
                    <TextBlock Text="{x:Bind Name}"
                               Style="{StaticResource BodyTextBlockStyle}"
                               TextTrimming="CharacterEllipsis" MaxLines="1" />
                    <TextBlock Text="{x:Bind Id}"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               Style="{StaticResource CaptionTextBlockStyle}" />
                </StackPanel>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid Padding="24,16,24,0" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title + cookie setup -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                x:Uid="Import_Title"
                Style="{StaticResource TitleTextBlockStyle}" />
            <Button
                x:Name="CookieSetupButton"
                Grid.Column="2"
                VerticalAlignment="Center"
                Click="CookieSetup_Click"
                Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="14" Glyph="&#xE8C7;" />
                    <TextBlock x:Uid="Import_CookieSetup" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Rejected files warning -->
        <InfoBar
            x:Name="RejectedWarningBar"
            Grid.Row="1"
            IsOpen="{x:Bind ViewModel.ShowRejectedWarning, Mode=TwoWay}"
            Severity="Warning"
            IsClosable="True" />

        <!-- Drop zone (shown when empty) -->
        <Border
            x:Name="DropZone"
            Grid.Row="2"
            CornerRadius="16"
            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
            BorderThickness="2"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay}">
            <Grid>
                <!-- Idle: drop hint -->
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="16"
                    Visibility="{x:Bind ViewModel.IsIdle, Mode=OneWay}">
                    <FontIcon
                        FontSize="64"
                        Glyph="&#xE896;"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        HorizontalAlignment="Center" />
                    <TextBlock
                        x:Uid="Import_DropZoneTitle"
                        Style="{StaticResource SubtitleTextBlockStyle}"
                        HorizontalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock
                        x:Uid="Import_DropZoneHint"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        HorizontalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                </StackPanel>

                <!-- Scanning: progress animation -->
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="16"
                    Visibility="{x:Bind ViewModel.IsAnalyzing, Mode=OneWay}">
                    <ProgressRing
                        Width="56" Height="56"
                        IsActive="True"
                        HorizontalAlignment="Center" />
                    <TextBlock
                        x:Uid="Import_ScanningHint"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        HorizontalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tab view (shown when items exist) -->
        <TabView
            Grid.Row="2"
            IsAddTabButtonVisible="False"
            TabWidthMode="SizeToContent"
            Visibility="{x:Bind ViewModel.HasItems, Mode=OneWay}">

            <!-- matched tab -->
            <TabViewItem x:Uid="Import_Tab_Matched" IsClosable="False">
                <ScrollViewer Padding="0,8,0,0">
                    <StackPanel Spacing="4" Padding="0,0,0,8">

                        <!-- Analyzing section: items waiting for metadata -->
                        <Expander
                            IsExpanded="True"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            Visibility="{x:Bind ViewModel.HasAnalyzingItems, Mode=OneWay}">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <ProgressRing Width="14" Height="14" IsActive="True" />
                                    <TextBlock x:Uid="Import_Analyzing"
                                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                                </StackPanel>
                            </Expander.Header>
                            <ItemsRepeater ItemsSource="{x:Bind ViewModel.AnalyzingItems}" Margin="24,4,0,4">
                                <ItemsRepeater.Layout>
                                    <StackLayout Spacing="2" />
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="models:ImportItem">
                                        <Grid Padding="4,4" ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border CornerRadius="4" Padding="6,2" VerticalAlignment="Center"
                                                    Background="{ThemeResource ControlFillColorDefaultBrush}">
                                                <TextBlock FontSize="11" Text="{x:Bind CardTypeText, Mode=OneWay}" />
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="{x:Bind FileName}"
                                                       Style="{StaticResource BodyTextBlockStyle}"
                                                       TextTrimming="CharacterEllipsis" MaxLines="1"
                                                       VerticalAlignment="Center" />
                                            <ProgressRing Grid.Column="2" Width="14" Height="14" IsActive="True"
                                                          VerticalAlignment="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </Expander>

                        <!-- Fetch-failed: artwork ID recognized but fetch returned null -->
                        <Expander
                            IsExpanded="True"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            Visibility="{x:Bind ViewModel.HasFetchFailedItems, Mode=OneWay}">
                            <Expander.Header>
                                <TextBlock x:Uid="Import_FetchFailed"
                                           Style="{StaticResource BodyStrongTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </Expander.Header>
                            <StackPanel Spacing="8" Margin="24,4,0,4">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" MaxWidth="180" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox
                                        x:Uid="Import_AuthorId"
                                        Text="{x:Bind ViewModel.BatchFetchFailedAuthorId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                    <Button
                                        Grid.Column="1"
                                        x:Uid="Import_SelectAuthor"
                                        Click="PickAuthorForFetchFailedBatch_Click"
                                        IsEnabled="{x:Bind ViewModel.HasSelectedFetchFailedGroups, Mode=OneWay}">
                                        <FontIcon FontSize="14" Glyph="&#xE716;" />
                                    </Button>

                                    <Button
                                        Grid.Column="2"
                                        Command="{x:Bind ViewModel.AssignBatchAuthorIdToFetchFailedCommand}">
                                        <FontIcon FontSize="14" Glyph="&#xE8FB;" />
                                    </Button>
                                </Grid>

                            <ItemsRepeater ItemsSource="{x:Bind ViewModel.FetchFailedGroups}">
                                <ItemsRepeater.Layout>
                                    <StackLayout Spacing="6" />
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ImportArtworkGroup">
                                        <Expander
                                            IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch">
                                            <Expander.Header>
                                                <Grid ColumnSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" MaxWidth="180" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <CheckBox
                                                        IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                                        VerticalAlignment="Center" />

                                                    <TextBlock Grid.Column="1"
                                                               Text="{x:Bind HeaderText}"
                                                               VerticalAlignment="Center"
                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                               Style="{StaticResource BodyTextBlockStyle}"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxLines="1" />

                                                    <Border Grid.Column="2" CornerRadius="4" Padding="6,2"
                                                            VerticalAlignment="Center"
                                                            Background="{ThemeResource ControlFillColorDefaultBrush}">
                                                        <TextBlock FontSize="11" Text="{x:Bind FileCount}" />
                                                    </Border>

                                                    <TextBox
                                                        Grid.Column="4"
                                                        x:Uid="Import_AuthorId"
                                                        Text="{x:Bind ManualAuthorId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                                    <Button
                                                        Grid.Column="3"
                                                        x:Uid="Import_SearchSauceNao"
                                                        CommandParameter="{x:Bind}"
                                                        Click="SearchSauceNaoForFetchFailed_Click">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <FontIcon FontSize="14" Glyph="&#xE721;" />
                                                            <TextBlock Text="SauceNao" />
                                                        </StackPanel>
                                                    </Button>

                                                    <Button
                                                        Grid.Column="5"
                                                        x:Uid="Import_SelectAuthor"
                                                        CommandParameter="{x:Bind}"
                                                        Click="PickAuthor_Click">
                                                        <FontIcon FontSize="14" Glyph="&#xE716;" />
                                                    </Button>

                                                    <Button
                                                        Grid.Column="6"
                                                        IsEnabled="{x:Bind CanAssignAuthor, Mode=OneWay}"
                                                        CommandParameter="{x:Bind}"
                                                        Click="AssignAuthor_Click">
                                                        <FontIcon FontSize="14" Glyph="&#xE8FB;" />
                                                    </Button>
                                                </Grid>
                                            </Expander.Header>

                                            <ItemsRepeater ItemsSource="{x:Bind Files}" Margin="24,6,0,4">
                                                <ItemsRepeater.Layout>
                                                    <StackLayout Spacing="6" />
                                                </ItemsRepeater.Layout>
                                                <ItemsRepeater.ItemTemplate>
                                                    <DataTemplate x:DataType="models:ImportItem">
                                                        <Grid Padding="4,4" ColumnSpacing="12">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>

                                                            <Border Width="144" Height="108"
                                                                    CornerRadius="6"
                                                                    Background="{ThemeResource ControlFillColorDefaultBrush}"
                                                                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                                                    BorderThickness="1">
                                                                <Image Stretch="UniformToFill">
                                                                    <Image.Source>
                                                                        <BitmapImage DecodePixelWidth="360"
                                                                                     UriSource="{x:Bind ThumbnailUri, Mode=OneWay}" />
                                                                    </Image.Source>
                                                                </Image>
                                                            </Border>

                                                            <StackPanel Grid.Column="1" Spacing="8" VerticalAlignment="Center">
                                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                                    <Border CornerRadius="4" Padding="6,2" VerticalAlignment="Center"
                                                                            Background="{ThemeResource ControlFillColorDefaultBrush}">
                                                                        <TextBlock FontSize="11" Text="{x:Bind CardTypeText, Mode=OneWay}" />
                                                                    </Border>
                                                                    <TextBlock Text="{x:Bind FileName}"
                                                                               Style="{StaticResource BodyTextBlockStyle}"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               MaxLines="1"
                                                                               VerticalAlignment="Center" />
                                                                </StackPanel>

                                                                <StackPanel
                                                                    x:Uid="Import_RatingTooltip"
                                                                    Orientation="Horizontal"
                                                                    Spacing="4">
                                                                    <ToggleButton
                                                                        MinWidth="48"
                                                                        Content="G"
                                                                        IsChecked="{x:Bind IsAllAgesRating, Mode=TwoWay}" />
                                                                    <ToggleButton
                                                                        MinWidth="64"
                                                                        Content="R-18"
                                                                        IsChecked="{x:Bind IsR18Rating, Mode=TwoWay}" />
                                                                    <ToggleButton
                                                                        MinWidth="72"
                                                                        Content="R-18G"
                                                                        IsChecked="{x:Bind IsR18GRating, Mode=TwoWay}" />
                                                                </StackPanel>
                                                            </StackPanel>

                                                            <Grid Grid.Column="2" VerticalAlignment="Center">
                                                                <ProgressRing Width="14" Height="14" IsActive="True"
                                                                              Visibility="{x:Bind ShowStatusRing, Mode=OneWay}" />
                                                                <FontIcon FontSize="14"
                                                                          Glyph="{x:Bind StatusGlyph, Mode=OneWay}"
                                                                          Visibility="{x:Bind ShowStatusGlyph, Mode=OneWay}" />
                                                            </Grid>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsRepeater.ItemTemplate>
                                            </ItemsRepeater>
                                        </Expander>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                            </StackPanel>
                        </Expander>

                        <!-- Resolved tree: rating → author → artwork → files -->
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.MatchedGroups, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <StackLayout Spacing="4" />
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:ImportRatingGroup">
                                    <Expander
                                        IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch">
                                        <Expander.Header>
                                            <TextBlock Text="{x:Bind Label}"
                                                       Style="{StaticResource BodyStrongTextBlockStyle}" />
                                        </Expander.Header>

                                        <!-- Author groups -->
                                        <ItemsRepeater ItemsSource="{x:Bind Authors}" Margin="24,4,0,4">
                                            <ItemsRepeater.Layout>
                                                <StackLayout Spacing="4" />
                                            </ItemsRepeater.Layout>
                                            <ItemsRepeater.ItemTemplate>
                                                <DataTemplate x:DataType="vm:ImportAuthorGroup">
                                                    <Expander
                                                        IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}"
                                                        HorizontalAlignment="Stretch"
                                                        HorizontalContentAlignment="Stretch">
                                                        <Expander.Header>
                                                            <TextBlock Text="{x:Bind HeaderText}"
                                                                       Style="{StaticResource BodyTextBlockStyle}" />
                                                        </Expander.Header>

                                                        <!-- Artwork groups -->
                                                        <ItemsRepeater ItemsSource="{x:Bind Artworks}" Margin="24,4,0,4">
                                                            <ItemsRepeater.Layout>
                                                                <StackLayout Spacing="4" />
                                                            </ItemsRepeater.Layout>
                                                            <ItemsRepeater.ItemTemplate>
                                                                <DataTemplate x:DataType="vm:ImportArtworkGroup">
                                                                    <Expander
                                                                        IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}"
                                                                        HorizontalAlignment="Stretch"
                                                                        HorizontalContentAlignment="Stretch">
                                                                        <Expander.Header>
                                                                            <TextBlock Text="{x:Bind HeaderText}"
                                                                                       Style="{StaticResource BodyTextBlockStyle}"
                                                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                                        </Expander.Header>

                                                                        <!-- File rows -->
                                                                        <ItemsRepeater ItemsSource="{x:Bind Files}" Margin="24,4,0,4">
                                                                            <ItemsRepeater.Layout>
                                                                                <StackLayout Spacing="2" />
                                                                            </ItemsRepeater.Layout>
                                                                            <ItemsRepeater.ItemTemplate>
                                                                                <DataTemplate x:DataType="models:ImportItem">
                                                                                    <Grid Padding="4,4" ColumnSpacing="10">
                                                                                        <Grid.ColumnDefinitions>
                                                                                            <ColumnDefinition Width="Auto" />
                                                                                            <ColumnDefinition Width="*" />
                                                                                            <ColumnDefinition Width="Auto" />
                                                                                            <ColumnDefinition Width="Auto" />
                                                                                        </Grid.ColumnDefinitions>

                                                                                        <!-- Card type badge -->
                                                                                        <Border CornerRadius="4" Padding="6,2" VerticalAlignment="Center"
                                                                                                Background="{ThemeResource ControlFillColorDefaultBrush}">
                                                                                            <TextBlock FontSize="11" Text="{x:Bind CardTypeText, Mode=OneWay}" />
                                                                                        </Border>

                                                                                        <!-- File name + destination -->
                                                                                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                                                                            <TextBlock Text="{x:Bind FileName}"
                                                                                                       Style="{StaticResource BodyTextBlockStyle}"
                                                                                                       TextTrimming="CharacterEllipsis" MaxLines="1" />
                                                                                            <TextBlock Text="{x:Bind DestinationPath, Mode=OneWay}"
                                                                                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                                                                       TextTrimming="CharacterEllipsis" MaxLines="1"
                                                                                                       Visibility="{x:Bind HasDestination, Mode=OneWay}" />
                                                                                        </StackPanel>

                                                                                        <!-- R-18 badge -->
                                                                                        <Border Grid.Column="2" CornerRadius="4" Padding="6,2" VerticalAlignment="Center"
                                                                                                Background="#D84315"
                                                                                                Visibility="{x:Bind IsR18OrAbove, Mode=OneWay}">
                                                                                            <TextBlock Text="{x:Bind RatingText, Mode=OneWay}"
                                                                                                       Foreground="White" FontSize="11" FontWeight="SemiBold" />
                                                                                        </Border>

                                                                                        <!-- Status -->
                                                                                        <Grid Grid.Column="3" VerticalAlignment="Center">
                                                                                            <ProgressRing Width="14" Height="14" IsActive="True"
                                                                                                          Visibility="{x:Bind ShowStatusRing, Mode=OneWay}" />
                                                                                            <FontIcon FontSize="14"
                                                                                                      Glyph="{x:Bind StatusGlyph, Mode=OneWay}"
                                                                                                      Visibility="{x:Bind ShowStatusGlyph, Mode=OneWay}" />
                                                                                        </Grid>
                                                                                    </Grid>
                                                                                </DataTemplate>
                                                                            </ItemsRepeater.ItemTemplate>
                                                                        </ItemsRepeater>

                                                                    </Expander>
                                                                </DataTemplate>
                                                            </ItemsRepeater.ItemTemplate>
                                                        </ItemsRepeater>

                                                    </Expander>
                                                </DataTemplate>
                                            </ItemsRepeater.ItemTemplate>
                                        </ItemsRepeater>

                                    </Expander>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>

                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>

            <!-- Unknown / unrecognized tab -->
            <TabViewItem x:Uid="Import_Tab_Unknown" IsClosable="False"
                         Visibility="{x:Bind ViewModel.HasUnknownItems, Mode=OneWay}">
                <Grid RowSpacing="8" Padding="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <InfoBar
                        IsOpen="True"
                        IsClosable="False"
                        Severity="Informational"
                        x:Uid="Import_UnknownHint" />
                    <Grid Grid.Row="1" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MaxWidth="180" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" MaxWidth="180" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBox
                            x:Uid="Import_ArtworkId"
                            Text="{x:Bind ViewModel.BatchManualArtworkId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <Button
                            Grid.Column="1"
                            x:Uid="Import_ResolveSelectedArtwork"
                            Command="{x:Bind ViewModel.AssignBatchArtworkIdToUnknownCommand}">
                            <FontIcon FontSize="14" Glyph="&#xE721;" />
                        </Button>

                        <TextBox
                            Grid.Column="2"
                            x:Uid="Import_AuthorId"
                            Text="{x:Bind ViewModel.BatchManualAuthorId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <Button
                            Grid.Column="3"
                            x:Uid="Import_SelectAuthor"
                            Click="PickAuthorForUnknownBatch_Click"
                            IsEnabled="{x:Bind ViewModel.HasSelectedUnknownItems, Mode=OneWay}">
                            <FontIcon FontSize="14" Glyph="&#xE716;" />
                        </Button>

                        <Button
                            Grid.Column="4"
                            Command="{x:Bind ViewModel.AssignBatchAuthorIdToUnknownCommand}">
                            <FontIcon FontSize="14" Glyph="&#xE8FB;" />
                        </Button>
                    </Grid>
                    <ScrollViewer Grid.Row="2">
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.UnknownGroups}">
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:ImportUnknownGroup">
                                    <Expander
                                        IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Margin="0,0,0,4">
                                        <Expander.Header>
                                            <Grid ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <CheckBox IsChecked="{x:Bind IsSelected, Mode=TwoWay}" MinWidth="0" />

                                                <TextBlock Grid.Column="1"
                                                           Text="{x:Bind HeaderText, Mode=OneWay}"
                                                           Style="{StaticResource BodyStrongTextBlockStyle}"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis" />

                                                <TextBox Grid.Column="2"
                                                         x:Uid="Import_ArtworkId"
                                                         MinWidth="140"
                                                         Text="{x:Bind ManualArtworkId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                                <Button Grid.Column="3"
                                                        x:Uid="Import_ResolveArtwork"
                                                        IsEnabled="{x:Bind CanAssignArtworkId, Mode=OneWay}"
                                                        CommandParameter="{x:Bind}"
                                                        Click="AssignArtworkIdToUnknownGroup_Click">
                                                    <FontIcon FontSize="14" Glyph="&#xE721;" />
                                                </Button>

                                                <TextBox Grid.Column="4"
                                                         x:Uid="Import_AuthorId"
                                                         MinWidth="140"
                                                         Text="{x:Bind ManualAuthorId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                                <Button Grid.Column="5"
                                                        x:Uid="Import_SelectAuthor"
                                                        CommandParameter="{x:Bind}"
                                                        Click="PickAuthorForUnknownGroup_Click">
                                                    <FontIcon FontSize="14" Glyph="&#xE716;" />
                                                </Button>

                                                <Button Grid.Column="6"
                                                        IsEnabled="{x:Bind CanAssignAuthor, Mode=OneWay}"
                                                        CommandParameter="{x:Bind}"
                                                        Click="AssignAuthorToUnknownGroup_Click">
                                                    <FontIcon FontSize="14" Glyph="&#xE8FB;" />
                                                </Button>

                                                <Button Grid.Column="7"
                                                        x:Uid="Import_RemoveGroup"
                                                        CommandParameter="{x:Bind}"
                                                        Click="RemoveUnknownGroup_Click">
                                                    <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                                </Button>
                                            </Grid>
                                        </Expander.Header>

                                        <ItemsRepeater ItemsSource="{x:Bind Files}">
                                            <ItemsRepeater.ItemTemplate>
                                                <DataTemplate x:DataType="models:ImportItem">
                                                    <Grid Padding="8,8" ColumnSpacing="12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <Border Width="144" Height="108"
                                                                CornerRadius="6"
                                                                Background="{ThemeResource ControlFillColorDefaultBrush}"
                                                                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                                                BorderThickness="1">
                                                            <Image Stretch="UniformToFill">
                                                                <Image.Source>
                                                                    <BitmapImage DecodePixelWidth="360"
                                                                                 UriSource="{x:Bind ThumbnailUri, Mode=OneWay}" />
                                                                </Image.Source>
                                                            </Image>
                                                        </Border>

                                                        <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                <Border CornerRadius="4" Padding="6,2" VerticalAlignment="Center"
                                                                        Background="{ThemeResource ControlFillColorDefaultBrush}">
                                                                    <TextBlock FontSize="11" Text="{x:Bind CardTypeText, Mode=OneWay}" />
                                                                </Border>
                                                                <TextBlock Text="{x:Bind FileName}"
                                                                           Style="{StaticResource BodyTextBlockStyle}"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           MaxLines="1"
                                                                           VerticalAlignment="Center" />
                                                            </StackPanel>

                                                            <StackPanel
                                                                x:Uid="Import_RatingTooltip"
                                                                Orientation="Horizontal"
                                                                Spacing="4">
                                                                <ToggleButton MinWidth="48" Content="G"
                                                                              IsChecked="{x:Bind IsAllAgesRating, Mode=TwoWay}" />
                                                                <ToggleButton MinWidth="64" Content="R-18"
                                                                              IsChecked="{x:Bind IsR18Rating, Mode=TwoWay}" />
                                                                <ToggleButton MinWidth="72" Content="R-18G"
                                                                              IsChecked="{x:Bind IsR18GRating, Mode=TwoWay}" />
                                                            </StackPanel>
                                                        </StackPanel>

                                                        <Button Grid.Column="2" VerticalAlignment="Top"
                                                                x:Uid="Import_RemoveItem"
                                                                CommandParameter="{x:Bind}"
                                                                Click="RemoveUnknownItem_Click">
                                                            <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                                        </Button>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsRepeater.ItemTemplate>
                                        </ItemsRepeater>
                                    </Expander>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </ScrollViewer>
                </Grid>
            </TabViewItem>

        </TabView>

        <!-- Action bar -->
        <Grid
            Grid.Row="3"
            Padding="0,8,0,16"
            ColumnSpacing="12"
            Visibility="{x:Bind ViewModel.HasItems, Mode=OneWay}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button
                Style="{StaticResource AccentButtonStyle}"
                Command="{x:Bind ViewModel.ImportAllCommand}"
                IsEnabled="{x:Bind ViewModel.IsIdle, Mode=OneWay}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="14" Glyph="&#xE896;" />
                    <TextBlock x:Uid="Import_ImportAllLabel" />
                </StackPanel>
            </Button>

            <Button
                Grid.Column="1"
                Command="{x:Bind ViewModel.ClearCommand}"
                IsEnabled="{x:Bind ViewModel.IsIdle, Mode=OneWay}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="14" Glyph="&#xE74D;" />
                    <TextBlock x:Uid="Import_ClearLabel" />
                </StackPanel>
            </Button>

            <Button
                Grid.Column="2"
                Command="{x:Bind ViewModel.UndoManualAssignmentCommand}"
                IsEnabled="{x:Bind ViewModel.CanUndoManualAssignment, Mode=OneWay}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="14" Glyph="&#xE7A7;" />
                    <TextBlock x:Uid="Import_UndoLabel" />
                </StackPanel>
            </Button>

            <NumberBox
                Grid.Column="3"
                x:Uid="Import_SubfolderThreshold"
                Minimum="-1"
                Maximum="99"
                SmallChange="1"
                SpinButtonPlacementMode="Compact"
                MinWidth="120"
                VerticalAlignment="Center"
                Value="{x:Bind ViewModel.ArtworkSubfolderThreshold, Mode=TwoWay}" />

            <StackPanel
                Grid.Column="5"
                Orientation="Horizontal"
                VerticalAlignment="Center"
                Spacing="12"
                Margin="8,0,0,0">

                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Border Background="#C62828" CornerRadius="4" Padding="6,2">
                        <TextBlock Text="R-18G" Foreground="White" FontSize="11" FontWeight="SemiBold" />
                    </Border>
                    <TextBlock Text="{x:Bind ViewModel.R18GCount, Mode=OneWay}"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Style="{StaticResource CaptionTextBlockStyle}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Border Background="#D84315" CornerRadius="4" Padding="6,2">
                        <TextBlock Text="R-18" Foreground="White" FontSize="11" FontWeight="SemiBold" />
                    </Border>
                    <TextBlock Text="{x:Bind ViewModel.R18Count, Mode=OneWay}"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Style="{StaticResource CaptionTextBlockStyle}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Border Background="#2E7D32" CornerRadius="4" Padding="6,2">
                        <TextBlock x:Uid="Import_AllAges" Foreground="White" FontSize="11" FontWeight="SemiBold" />
                    </Border>
                    <TextBlock Text="{x:Bind ViewModel.AllAgesCount, Mode=OneWay}"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Style="{StaticResource CaptionTextBlockStyle}" />
                </StackPanel>

                <TextBlock Text="|" Foreground="{ThemeResource TextFillColorTertiaryBrush}" VerticalAlignment="Center" />

                <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon FontSize="12" Glyph="&#xE8B9;" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="{x:Bind ViewModel.SceneCount, Mode=OneWay}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Style="{StaticResource CaptionTextBlockStyle}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon FontSize="12" Glyph="&#xE77B;" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="{x:Bind ViewModel.CharaCount, Mode=OneWay}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Style="{StaticResource CaptionTextBlockStyle}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon FontSize="12" Glyph="&#xE78A;" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="{x:Bind ViewModel.CoordCount, Mode=OneWay}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Style="{StaticResource CaptionTextBlockStyle}" />
                </StackPanel>

                <ProgressRing
                    Width="14" Height="14"
                    IsActive="True"
                    Visibility="{x:Bind ViewModel.IsAnalyzing, Mode=OneWay}" />
            </StackPanel>

            <StackPanel
                Grid.Column="6"
                Orientation="Horizontal"
                Spacing="8"
                VerticalAlignment="Center"
                Visibility="{x:Bind ViewModel.IsImporting, Mode=OneWay}">
                <ProgressRing Width="16" Height="16" IsActive="True" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}">
                    <Run Text="{x:Bind ViewModel.CompletedCount, Mode=OneWay}" />
                    <Run Text="/" />
                    <Run Text="{x:Bind ViewModel.Items.Count, Mode=OneWay}" />
                </TextBlock>
            </StackPanel>
        </Grid>

    </Grid>
</Page>
