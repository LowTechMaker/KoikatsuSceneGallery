<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="KoikatsuSceneGallery.Pages.ImportPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:KoikatsuSceneGallery.Models"
    mc:Ignorable="d"
    AllowDrop="True"
    DragOver="Page_DragOver"
    Drop="Page_Drop">

    <Grid Padding="24,16,24,0" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title + summary bar -->
        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock
                x:Uid="Import_Title"
                Style="{StaticResource TitleTextBlockStyle}" />

            <!-- Summary badges -->
            <StackPanel
                Grid.Column="1"
                Orientation="Horizontal"
                VerticalAlignment="Center"
                Spacing="12"
                Visibility="{x:Bind ViewModel.HasItems, Mode=OneWay}">

                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Border Background="#C62828" CornerRadius="4" Padding="6,2">
                        <TextBlock Text="R-18G" Foreground="White" FontSize="11" FontWeight="SemiBold" />
                    </Border>
                    <TextBlock Text="{x:Bind ViewModel.R18GCount, Mode=OneWay}"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Style="{StaticResource CaptionTextBlockStyle}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Border Background="#D84315" CornerRadius="4" Padding="6,2">
                        <TextBlock Text="R-18" Foreground="White" FontSize="11" FontWeight="SemiBold" />
                    </Border>
                    <TextBlock Text="{x:Bind ViewModel.R18Count, Mode=OneWay}"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Style="{StaticResource CaptionTextBlockStyle}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Border Background="#2E7D32" CornerRadius="4" Padding="6,2">
                        <TextBlock x:Uid="Import_AllAges" Foreground="White" FontSize="11" FontWeight="SemiBold" />
                    </Border>
                    <TextBlock Text="{x:Bind ViewModel.AllAgesCount, Mode=OneWay}"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Style="{StaticResource CaptionTextBlockStyle}" />
                </StackPanel>

                <TextBlock Text="|" Foreground="{ThemeResource TextFillColorTertiaryBrush}" VerticalAlignment="Center" />

                <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon FontSize="12" Glyph="&#xE8B9;"
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="{x:Bind ViewModel.SceneCount, Mode=OneWay}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Style="{StaticResource CaptionTextBlockStyle}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon FontSize="12" Glyph="&#xE77B;"
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="{x:Bind ViewModel.CharaCount, Mode=OneWay}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Style="{StaticResource CaptionTextBlockStyle}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon FontSize="12" Glyph="&#xE78A;"
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="{x:Bind ViewModel.CoordCount, Mode=OneWay}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Style="{StaticResource CaptionTextBlockStyle}" />
                </StackPanel>

                <ProgressRing
                    Width="16" Height="16"
                    IsActive="True"
                    Visibility="{x:Bind ViewModel.IsAnalyzing, Mode=OneWay}" />
            </StackPanel>
        </Grid>

        <!-- Rejected files warning -->
        <InfoBar
            x:Name="RejectedWarningBar"
            Grid.Row="1"
            VerticalAlignment="Top"
            IsOpen="{x:Bind ViewModel.ShowRejectedWarning, Mode=TwoWay}"
            Severity="Warning"
            IsClosable="True" />

        <!-- Drop zone (shown when empty) -->
        <Border
            x:Name="DropZone"
            Grid.Row="1"
            CornerRadius="16"
            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
            BorderThickness="2"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay}">
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="16">
                <FontIcon
                    FontSize="64"
                    Glyph="&#xE896;"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    HorizontalAlignment="Center" />
                <TextBlock
                    x:Uid="Import_DropZoneTitle"
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    HorizontalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock
                    x:Uid="Import_DropZoneHint"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    HorizontalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
            </StackPanel>
        </Border>

        <!-- Import queue (shown when items exist) -->
        <ListView
            x:Name="ImportList"
            Grid.Row="1"
            ItemsSource="{x:Bind ViewModel.Items, Mode=OneWay}"
            SelectionMode="None"
            Visibility="{x:Bind ViewModel.HasItems, Mode=OneWay}">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:ImportItem">
                    <Grid
                        Padding="8,6"
                        ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Card type badge -->
                        <Border
                            CornerRadius="4"
                            Padding="6,2"
                            VerticalAlignment="Center"
                            Background="{ThemeResource ControlFillColorDefaultBrush}">
                            <TextBlock
                                FontSize="11"
                                Text="{x:Bind CardTypeText, Mode=OneWay}" />
                        </Border>

                        <!-- File name + author + destination -->
                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                            <TextBlock
                                Text="{x:Bind FileName}"
                                Style="{StaticResource BodyTextBlockStyle}"
                                TextTrimming="CharacterEllipsis"
                                MaxLines="1" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock
                                    Text="{x:Bind AuthorName, Mode=OneWay}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Visibility="{x:Bind HasAuthor, Mode=OneWay}" />
                                <TextBlock
                                    Text="{x:Bind DestinationPath, Mode=OneWay}"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    TextTrimming="CharacterEllipsis"
                                    MaxLines="1"
                                    Visibility="{x:Bind HasDestination, Mode=OneWay}" />
                            </StackPanel>
                        </StackPanel>

                        <!-- R-18 badge -->
                        <Border
                            Grid.Column="2"
                            CornerRadius="4"
                            Padding="6,2"
                            VerticalAlignment="Center"
                            Background="#D84315"
                            Visibility="{x:Bind IsR18OrAbove, Mode=OneWay}">
                            <TextBlock
                                Text="{x:Bind RatingText, Mode=OneWay}"
                                Foreground="White"
                                FontSize="11"
                                FontWeight="SemiBold" />
                        </Border>

                        <!-- Status indicator -->
                        <Grid Grid.Column="3" VerticalAlignment="Center">
                            <ProgressRing
                                Width="14" Height="14"
                                IsActive="True"
                                Visibility="{x:Bind ShowStatusRing, Mode=OneWay}" />
                            <FontIcon
                                FontSize="14"
                                Glyph="{x:Bind StatusGlyph, Mode=OneWay}"
                                Visibility="{x:Bind ShowStatusGlyph, Mode=OneWay}" />
                        </Grid>

                        <!-- Exclude toggle -->
                        <CheckBox
                            Grid.Column="4"
                            IsChecked="{x:Bind IsExcluded, Mode=TwoWay}"
                            VerticalAlignment="Center"
                            MinWidth="0"
                            Content="Skip" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Action bar -->
        <Grid
            Grid.Row="2"
            Padding="0,8,0,16"
            ColumnSpacing="12"
            Visibility="{x:Bind ViewModel.HasItems, Mode=OneWay}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button
                Style="{StaticResource AccentButtonStyle}"
                Command="{x:Bind ViewModel.ImportAllCommand}"
                IsEnabled="{x:Bind ViewModel.IsIdle, Mode=OneWay}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="14" Glyph="&#xE896;" />
                    <TextBlock x:Uid="Import_ImportAllLabel" />
                </StackPanel>
            </Button>

            <Button
                Grid.Column="1"
                Command="{x:Bind ViewModel.ClearCommand}"
                IsEnabled="{x:Bind ViewModel.IsIdle, Mode=OneWay}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="14" Glyph="&#xE74D;" />
                    <TextBlock x:Uid="Import_ClearLabel" />
                </StackPanel>
            </Button>

            <StackPanel
                Grid.Column="3"
                Orientation="Horizontal"
                Spacing="8"
                VerticalAlignment="Center"
                Visibility="{x:Bind ViewModel.IsImporting, Mode=OneWay}">
                <ProgressRing Width="16" Height="16" IsActive="True" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}">
                    <Run Text="{x:Bind ViewModel.CompletedCount, Mode=OneWay}" />
                    <Run Text="/" />
                    <Run Text="{x:Bind ViewModel.Items.Count, Mode=OneWay}" />
                </TextBlock>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
