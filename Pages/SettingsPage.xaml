<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="KoikatsuSceneGallery.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:KoikatsuSceneGallery.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24,16,24,0" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            x:Uid="Settings_Title"
            Style="{StaticResource TitleTextBlockStyle}" />

        <Pivot Grid.Row="1">

            <!-- General Tab -->
            <PivotItem x:Uid="Settings_TabGeneral">
                <ScrollViewer Padding="0,16,0,24">
                    <StackPanel Spacing="32">

                        <!-- Display Section -->
                        <StackPanel Spacing="16">
                            <TextBlock
                                x:Uid="Settings_DisplayHeader"
                                Style="{StaticResource SubtitleTextBlockStyle}" />

                            <ToggleSwitch
                                x:Uid="Settings_ShowFileNames"
                                IsOn="{x:Bind ViewModel.ShowFileNames, Mode=TwoWay}" />

                            <ToggleSwitch
                                x:Uid="Settings_ScrollToTop"
                                IsOn="{x:Bind ViewModel.ScrollToTopOnSort, Mode=TwoWay}" />
                        </StackPanel>

                        <!-- Language Section -->
                        <StackPanel Spacing="16">
                            <TextBlock
                                x:Uid="Settings_LanguageHeader"
                                Style="{StaticResource SubtitleTextBlockStyle}" />
                            <TextBlock
                                x:Uid="Settings_LanguageDesc"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                            <ComboBox
                                x:Name="LanguageComboBox"
                                MinWidth="240"
                                SelectedValuePath="Tag"
                                SelectedValue="{x:Bind ViewModel.SelectedLanguage, Mode=TwoWay}">
                                <ComboBoxItem x:Uid="Settings_LanguageSystem" Tag="" />
                                <ComboBoxItem Content="English" Tag="en-US" />
                                <ComboBoxItem Content="简体中文" Tag="zh-Hans" />
                                <ComboBoxItem Content="繁體中文" Tag="zh-Hant" />
                            </ComboBox>

                            <InfoBar
                                x:Uid="Settings_RestartInfo"
                                IsClosable="False"
                                IsOpen="{x:Bind ViewModel.ShowRestartHint, Mode=OneWay}"
                                Severity="Informational">
                                <InfoBar.ActionButton>
                                    <Button x:Uid="Settings_RestartButton" Click="RestartApp_Click" />
                                </InfoBar.ActionButton>
                            </InfoBar>
                        </StackPanel>

                        <!-- SauceNao Section -->
                        <StackPanel Spacing="16">
                            <TextBlock
                                x:Uid="Settings_SauceNaoHeader"
                                Style="{StaticResource SubtitleTextBlockStyle}" />
                            <TextBlock
                                x:Uid="Settings_SauceNaoDesc"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextWrapping="Wrap" />
                            <PasswordBox
                                x:Uid="Settings_SauceNaoApiKey"
                                MinWidth="320"
                                MaxWidth="520"
                                HorizontalAlignment="Left"
                                Password="{x:Bind ViewModel.SauceNaoApiKey, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

            <!-- Folders Tab -->
            <PivotItem x:Uid="Settings_TabFolders">
                <ScrollViewer Padding="0,16,0,24">
                    <StackPanel Spacing="32">

                        <!-- Scene Folder Paths Section -->
                        <StackPanel Spacing="16">
                            <TextBlock
                                x:Uid="Settings_FoldersHeader"
                                Style="{StaticResource SubtitleTextBlockStyle}" />
                            <TextBlock
                                x:Uid="Settings_FoldersDesc"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                            <Button Command="{x:Bind ViewModel.AddFolderCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon FontSize="16" Glyph="&#xE8DA;" />
                                    <TextBlock x:Uid="Settings_AddFolder" />
                                </StackPanel>
                            </Button>

                            <ListView
                                x:Name="FolderListView"
                                ItemsSource="{x:Bind ViewModel.FolderPaths, Mode=OneWay}"
                                SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <Grid Padding="8,12" ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <FontIcon
                                                VerticalAlignment="Center"
                                                FontSize="16"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Glyph="&#xE8B7;" />

                                            <TextBlock
                                                Grid.Column="1"
                                                VerticalAlignment="Center"
                                                Text="{x:Bind}"
                                                TextTrimming="CharacterEllipsis"
                                                ToolTipService.ToolTip="{x:Bind}" />

                                            <Button
                                                x:Uid="Settings_RemoveFolder"
                                                Grid.Column="2"
                                                VerticalAlignment="Center"
                                                CommandParameter="{x:Bind}"
                                                Click="RemoveFolder_Click"
                                                Style="{StaticResource SubtleButtonStyle}">
                                                <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <TextBlock
                                x:Uid="Settings_NoFolders"
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                Visibility="{x:Bind ViewModel.HasNoFolders, Mode=OneWay}" />
                        </StackPanel>

                        <!-- Character Card Folders Section -->
                        <StackPanel Spacing="16">
                            <TextBlock
                                x:Uid="Settings_CharaFoldersHeader"
                                Style="{StaticResource SubtitleTextBlockStyle}" />
                            <TextBlock
                                x:Uid="Settings_CharaFoldersDesc"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                            <Button Command="{x:Bind ViewModel.AddCharacterFolderCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon FontSize="16" Glyph="&#xE8DA;" />
                                    <TextBlock x:Uid="Settings_AddFolder" />
                                </StackPanel>
                            </Button>

                            <ListView
                                x:Name="CharacterFolderListView"
                                ItemsSource="{x:Bind ViewModel.CharacterFolderPaths, Mode=OneWay}"
                                SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <Grid Padding="8,12" ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <FontIcon
                                                VerticalAlignment="Center"
                                                FontSize="16"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Glyph="&#xE8B7;" />

                                            <TextBlock
                                                Grid.Column="1"
                                                VerticalAlignment="Center"
                                                Text="{x:Bind}"
                                                TextTrimming="CharacterEllipsis"
                                                ToolTipService.ToolTip="{x:Bind}" />

                                            <Button
                                                x:Uid="Settings_RemoveFolder"
                                                Grid.Column="2"
                                                VerticalAlignment="Center"
                                                CommandParameter="{x:Bind}"
                                                Click="RemoveCharacterFolder_Click"
                                                Style="{StaticResource SubtleButtonStyle}">
                                                <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <TextBlock
                                x:Uid="Settings_NoFolders"
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                Visibility="{x:Bind ViewModel.HasNoCharacterFolders, Mode=OneWay}" />
                        </StackPanel>

                        <!-- Coordinate Card Folders Section -->
                        <StackPanel Spacing="16">
                            <TextBlock
                                x:Uid="Settings_CoordFoldersHeader"
                                Style="{StaticResource SubtitleTextBlockStyle}" />
                            <TextBlock
                                x:Uid="Settings_CoordFoldersDesc"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                            <Button Command="{x:Bind ViewModel.AddCoordinateFolderCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon FontSize="16" Glyph="&#xE8DA;" />
                                    <TextBlock x:Uid="Settings_AddFolder" />
                                </StackPanel>
                            </Button>

                            <ListView
                                x:Name="CoordinateFolderListView"
                                ItemsSource="{x:Bind ViewModel.CoordinateFolderPaths, Mode=OneWay}"
                                SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <Grid Padding="8,12" ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <FontIcon
                                                VerticalAlignment="Center"
                                                FontSize="16"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Glyph="&#xE8B7;" />

                                            <TextBlock
                                                Grid.Column="1"
                                                VerticalAlignment="Center"
                                                Text="{x:Bind}"
                                                TextTrimming="CharacterEllipsis"
                                                ToolTipService.ToolTip="{x:Bind}" />

                                            <Button
                                                x:Uid="Settings_RemoveFolder"
                                                Grid.Column="2"
                                                VerticalAlignment="Center"
                                                CommandParameter="{x:Bind}"
                                                Click="RemoveCoordinateFolder_Click"
                                                Style="{StaticResource SubtleButtonStyle}">
                                                <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <TextBlock
                                x:Uid="Settings_NoFolders"
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                Visibility="{x:Bind ViewModel.HasNoCoordinateFolders, Mode=OneWay}" />
                        </StackPanel>

                        <!-- Import Subfolder Section -->
                        <StackPanel Spacing="16">
                            <TextBlock
                                x:Uid="Settings_ImportSubfolderHeader"
                                Style="{StaticResource SubtitleTextBlockStyle}" />
                            <TextBlock
                                x:Uid="Settings_ImportSubfolderDesc"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextWrapping="Wrap" />

                            <StackPanel Spacing="4">
                                <TextBlock
                                    x:Uid="Settings_ImportSubfolderLabel"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBox
                                    x:Uid="Settings_ImportSubfolderPlaceholder"
                                    MinWidth="320"
                                    HorizontalAlignment="Left"
                                    Text="{x:Bind ViewModel.ImportSubfolder, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            </StackPanel>

                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

            <!-- Filters Tab -->
            <PivotItem x:Uid="Settings_TabFilters">
                <ScrollViewer Padding="0,16,0,24">
                    <StackPanel Spacing="32">

                        <!-- Scene Resolution Filter Section -->
                        <StackPanel Spacing="16">
                            <TextBlock
                                x:Uid="Settings_ResolutionHeader"
                                Style="{StaticResource SubtitleTextBlockStyle}" />
                            <TextBlock
                                x:Uid="Settings_ResolutionDesc"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                            <ToggleSwitch
                                x:Uid="Settings_ResolutionToggle"
                                IsOn="{x:Bind ViewModel.ResolutionFilterEnabled, Mode=TwoWay}" />

                            <StackPanel
                                Spacing="12"
                                Visibility="{x:Bind ViewModel.ResolutionFilterEnabled, Mode=OneWay}">

                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" MaxWidth="240" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox
                                        x:Name="ResolutionInput"
                                        x:Uid="Settings_ResolutionInput"
                                        KeyDown="ResolutionInput_KeyDown" />

                                    <Button
                                        Grid.Column="1"
                                        Click="AddResolution_Click"
                                        Style="{StaticResource AccentButtonStyle}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontSize="14" Glyph="&#xE710;" />
                                            <TextBlock x:Uid="Settings_AddResolution" />
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <ListView
                                    x:Name="ResolutionListView"
                                    ItemsSource="{x:Bind ViewModel.AllowedResolutions, Mode=OneWay}"
                                    SelectionMode="None">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <Grid Padding="8,8" ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <FontIcon
                                                    VerticalAlignment="Center"
                                                    FontSize="16"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Glyph="&#xE740;" />

                                                <TextBlock
                                                    Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    Text="{x:Bind}" />

                                                <Button
                                                    x:Uid="Settings_RemoveResolution"
                                                    Grid.Column="2"
                                                    VerticalAlignment="Center"
                                                    CommandParameter="{x:Bind}"
                                                    Click="RemoveResolution_Click"
                                                    Style="{StaticResource SubtleButtonStyle}">
                                                    <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </StackPanel>

                        <!-- Character Resolution Filter Section -->
                        <StackPanel Spacing="16">
                            <TextBlock
                                x:Uid="Settings_CharaResolutionHeader"
                                Style="{StaticResource SubtitleTextBlockStyle}" />
                            <TextBlock
                                x:Uid="Settings_CharaResolutionDesc"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                            <ToggleSwitch
                                x:Uid="Settings_CharaResolutionToggle"
                                IsOn="{x:Bind ViewModel.CharacterResolutionFilterEnabled, Mode=TwoWay}" />

                            <StackPanel
                                Spacing="12"
                                Visibility="{x:Bind ViewModel.CharacterResolutionFilterEnabled, Mode=OneWay}">

                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" MaxWidth="240" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox
                                        x:Name="CharacterResolutionInput"
                                        x:Uid="Settings_CharaResolutionInput"
                                        KeyDown="CharacterResolutionInput_KeyDown" />

                                    <Button
                                        Grid.Column="1"
                                        Click="AddCharacterResolution_Click"
                                        Style="{StaticResource AccentButtonStyle}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontSize="14" Glyph="&#xE710;" />
                                            <TextBlock x:Uid="Settings_AddCharaResolution" />
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <ListView
                                    x:Name="CharacterResolutionListView"
                                    ItemsSource="{x:Bind ViewModel.CharacterAllowedResolutions, Mode=OneWay}"
                                    SelectionMode="None">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <Grid Padding="8,8" ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <FontIcon
                                                    VerticalAlignment="Center"
                                                    FontSize="16"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Glyph="&#xE740;" />

                                                <TextBlock
                                                    Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    Text="{x:Bind}" />

                                                <Button
                                                    x:Uid="Settings_RemoveCharaResolution"
                                                    Grid.Column="2"
                                                    VerticalAlignment="Center"
                                                    CommandParameter="{x:Bind}"
                                                    Click="RemoveCharacterResolution_Click"
                                                    Style="{StaticResource SubtleButtonStyle}">
                                                    <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </StackPanel>

                        <!-- Coordinate Resolution Filter Section -->
                        <StackPanel Spacing="16">
                            <TextBlock
                                x:Uid="Settings_CoordResolutionHeader"
                                Style="{StaticResource SubtitleTextBlockStyle}" />
                            <TextBlock
                                x:Uid="Settings_CoordResolutionDesc"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                            <ToggleSwitch
                                x:Uid="Settings_CoordResolutionToggle"
                                IsOn="{x:Bind ViewModel.CoordinateResolutionFilterEnabled, Mode=TwoWay}" />

                            <StackPanel
                                Spacing="12"
                                Visibility="{x:Bind ViewModel.CoordinateResolutionFilterEnabled, Mode=OneWay}">

                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" MaxWidth="240" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox
                                        x:Name="CoordinateResolutionInput"
                                        x:Uid="Settings_CoordResolutionInput"
                                        KeyDown="CoordinateResolutionInput_KeyDown" />

                                    <Button
                                        Grid.Column="1"
                                        Click="AddCoordinateResolution_Click"
                                        Style="{StaticResource AccentButtonStyle}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontSize="14" Glyph="&#xE710;" />
                                            <TextBlock x:Uid="Settings_AddCoordResolution" />
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <ListView
                                    x:Name="CoordinateResolutionListView"
                                    ItemsSource="{x:Bind ViewModel.CoordinateAllowedResolutions, Mode=OneWay}"
                                    SelectionMode="None">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <Grid Padding="8,8" ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <FontIcon
                                                    VerticalAlignment="Center"
                                                    FontSize="16"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Glyph="&#xE740;" />

                                                <TextBlock
                                                    Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    Text="{x:Bind}" />

                                                <Button
                                                    x:Uid="Settings_RemoveCoordResolution"
                                                    Grid.Column="2"
                                                    VerticalAlignment="Center"
                                                    CommandParameter="{x:Bind}"
                                                    Click="RemoveCoordinateResolution_Click"
                                                    Style="{StaticResource SubtleButtonStyle}">
                                                    <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </StackPanel>

                        <!-- Plugin Analysis Section -->
                        <StackPanel Spacing="16">
                            <TextBlock
                                x:Uid="Settings_PluginHeader"
                                Style="{StaticResource SubtitleTextBlockStyle}" />
                            <TextBlock
                                x:Uid="Settings_PluginDesc"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                            <ToggleSwitch
                                x:Uid="Settings_PluginToggle"
                                IsOn="{x:Bind ViewModel.PluginAnalysisEnabled, Mode=TwoWay}" />

                            <StackPanel
                                Spacing="12"
                                Visibility="{x:Bind ViewModel.PluginAnalysisEnabled, Mode=OneWay}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button
                                        Command="{x:Bind ViewModel.ScanMissingMetadataCommand}"
                                        IsEnabled="{x:Bind GalleryViewModel.IsNotParsingMetadata, Mode=OneWay}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontSize="14" Glyph="&#xE895;" />
                                            <TextBlock x:Uid="Settings_ScanMissing" />
                                        </StackPanel>
                                    </Button>

                                    <Button
                                        Command="{x:Bind ViewModel.RescanMetadataCommand}"
                                        IsEnabled="{x:Bind GalleryViewModel.IsNotParsingMetadata, Mode=OneWay}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontSize="14" Glyph="&#xE72C;" />
                                            <TextBlock x:Uid="Settings_RescanAll" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>

                                <StackPanel
                                    Orientation="Horizontal"
                                    Spacing="8"
                                    VerticalAlignment="Center"
                                    Visibility="{x:Bind GalleryViewModel.IsParsingMetadata, Mode=OneWay}">
                                    <ProgressRing
                                        Width="16"
                                        Height="16"
                                        IsActive="True" />
                                    <TextBlock
                                        x:Uid="Settings_ScanProgress"
                                        VerticalAlignment="Center"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{x:Bind GalleryViewModel.PendingMetadataCount, Mode=OneWay}" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

            <!-- Advanced Tab -->
            <PivotItem x:Uid="Settings_TabAdvanced">
                <ScrollViewer Padding="0,16,0,24">
                    <StackPanel Spacing="32">

                        <!-- Cache Section -->
                        <StackPanel Spacing="16">
                            <TextBlock
                                x:Uid="Settings_CacheHeader"
                                Style="{StaticResource SubtitleTextBlockStyle}" />
                            <TextBlock
                                x:Uid="Settings_CacheDesc"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                            <StackPanel Spacing="4">
                                <TextBlock
                                    x:Uid="Settings_CacheFolderLabel"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.CacheFolderDisplay, Mode=OneWay}"
                                    TextWrapping="Wrap"
                                    IsTextSelectionEnabled="True" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Command="{x:Bind ViewModel.ChangeCacheFolderCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon FontSize="14" Glyph="&#xE8DA;" />
                                        <TextBlock x:Uid="Settings_ChangeFolder" />
                                    </StackPanel>
                                </Button>

                                <Button Command="{x:Bind ViewModel.ResetCacheFolderCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon FontSize="14" Glyph="&#xE777;" />
                                        <TextBlock x:Uid="Settings_ResetDefault" />
                                    </StackPanel>
                                </Button>

                                <Button Click="ClearCache_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                        <TextBlock x:Uid="Settings_ClearCache" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>

                        <!-- Cache Buffer Section -->
                        <StackPanel Spacing="16">
                            <TextBlock
                                x:Uid="Settings_CacheBufferDesc"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                            <InfoBar
                                x:Uid="Settings_CacheBufferWarning"
                                IsClosable="False"
                                IsOpen="True"
                                Severity="Warning" />

                            <NumberBox
                                x:Uid="Settings_CacheBuffer"
                                MinWidth="240"
                                HorizontalAlignment="Left"
                                LargeChange="4"
                                Maximum="40"
                                Minimum="2"
                                SmallChange="2"
                                SpinButtonPlacementMode="Inline"
                                Value="{x:Bind ViewModel.CacheLength, Mode=TwoWay}" />
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

            <!-- Plugins Tab -->
            <PivotItem x:Uid="Settings_TabPlugins">
                <ScrollViewer Padding="0,16,0,24">
                    <StackPanel Spacing="16">
                        <TextBlock
                            x:Uid="Plugins_Header"
                            Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock
                            x:Uid="Plugins_Desc"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextWrapping="Wrap" />

                        <TextBlock
                            x:Uid="Plugins_RestartNote"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                        <TextBlock
                            x:Uid="Plugins_Empty"
                            Opacity="0.6"
                            Visibility="{x:Bind HasNoPlugins}" />

                        <ItemsControl ItemsSource="{x:Bind PluginItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="local:PluginListItem">
                                    <Grid
                                        Margin="0,0,0,8"
                                        Padding="16,12"
                                        ColumnSpacing="12"
                                        CornerRadius="8"
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <FontIcon
                                            VerticalAlignment="Center"
                                            Glyph="&#xEA86;" />

                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock
                                                    Style="{StaticResource BodyStrongTextBlockStyle}"
                                                    Text="{x:Bind Name}" />
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Style="{StaticResource CaptionTextBlockStyle}"
                                                    Text="{x:Bind Version}" />
                                            </StackPanel>
                                            <TextBlock
                                                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                Text="{x:Bind Error}"
                                                TextWrapping="Wrap"
                                                Visibility="{x:Bind HasError}" />
                                        </StackPanel>

                                        <TextBlock
                                            Grid.Column="2"
                                            VerticalAlignment="Center"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Style="{StaticResource CaptionTextBlockStyle}"
                                            Text="{x:Bind StatusText}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Button Click="OpenPluginsFolder_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="14" Glyph="&#xE8DA;" />
                                <TextBlock x:Uid="Plugins_OpenFolder" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

            <!-- OCD Tab -->
            <PivotItem x:Uid="Settings_TabOcd">
                <ScrollViewer Padding="0,16,0,24">
                    <StackPanel Spacing="32">
                        <StackPanel Spacing="16">
                            <TextBlock
                                x:Uid="Settings_OcdDesc"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                            <ToggleSwitch
                                x:Uid="Settings_SizeSelector"
                                IsOn="{x:Bind ViewModel.SizeSelectorEnabled, Mode=TwoWay}" />

                            <ToggleSwitch
                                x:Uid="Settings_VisualSimilarity"
                                IsOn="{x:Bind ViewModel.UseVisualSimilarity, Mode=TwoWay}" />
                        </StackPanel>

                        <!-- Import folder naming -->
                        <StackPanel Spacing="16">
                            <TextBlock
                                x:Uid="Settings_FolderNamingHeader"
                                Style="{StaticResource SubtitleTextBlockStyle}" />
                            <TextBlock
                                x:Uid="Settings_FolderNamingDesc"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextWrapping="Wrap" />

                            <TextBox
                                x:Uid="Settings_AuthorFolderFormat"
                                MinWidth="320" HorizontalAlignment="Left"
                                Text="{x:Bind ViewModel.AuthorFolderFormat, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            <TextBox
                                x:Uid="Settings_ArtworkFolderFormat"
                                MinWidth="320" HorizontalAlignment="Left"
                                Text="{x:Bind ViewModel.ArtworkFolderFormat, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            <TextBox
                                x:Uid="Settings_UnknownFolderName"
                                MinWidth="320" HorizontalAlignment="Left"
                                Text="{x:Bind ViewModel.UnknownFolderName, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />

                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" MaxWidth="320" />
                                    <ColumnDefinition Width="*" MaxWidth="320" />
                                </Grid.ColumnDefinitions>
                                <TextBox
                                    x:Uid="Settings_KoikatsuFolderName"
                                    Text="{x:Bind ViewModel.KoikatsuFolderName, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                <TextBox
                                    Grid.Column="1"
                                    x:Uid="Settings_KoikatsuSunshineFolderName"
                                    Text="{x:Bind ViewModel.KoikatsuSunshineFolderName, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            </Grid>

                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" MaxWidth="200" />
                                    <ColumnDefinition Width="*" MaxWidth="200" />
                                    <ColumnDefinition Width="*" MaxWidth="200" />
                                </Grid.ColumnDefinitions>
                                <TextBox
                                    x:Uid="Settings_GFolderName"
                                    Text="{x:Bind ViewModel.GFolderName, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                <TextBox
                                    Grid.Column="1"
                                    x:Uid="Settings_R18FolderName"
                                    Text="{x:Bind ViewModel.R18FolderName, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                <TextBox
                                    Grid.Column="2"
                                    x:Uid="Settings_R18GFolderName"
                                    Text="{x:Bind ViewModel.R18GFolderName, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

        </Pivot>
    </Grid>
</Page>
