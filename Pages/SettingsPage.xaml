<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="KoikatsuSceneGallery.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:KoikatsuSceneGallery.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24,16,24,0" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            x:Uid="Settings_Title"
            Style="{StaticResource TitleTextBlockStyle}" />

        <Pivot Grid.Row="1">

            <!-- General Tab -->
            <PivotItem x:Uid="Settings_TabGeneral">
                <ScrollViewer Padding="0,16,0,24">
                    <StackPanel Spacing="4">

                        <!-- Display Section -->
                        <TextBlock
                            x:Uid="Settings_DisplayHeader"
                            Margin="1,0,0,4"
                            Style="{StaticResource BodyStrongTextBlockStyle}" />

                        <controls:SettingsCard
                            x:Uid="SC_ShowFileNames"
                            AutomationProperties.AutomationId="SettingsShowFileNamesCard">
                            <controls:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE91B;" />
                            </controls:SettingsCard.HeaderIcon>
                            <ToggleSwitch
                                AutomationProperties.AutomationId="SettingsShowFileNamesToggle"
                                IsOn="{x:Bind ViewModel.ShowFileNames, Mode=TwoWay}" />
                        </controls:SettingsCard>

                        <controls:SettingsCard
                            x:Uid="SC_ScrollToTop"
                            AutomationProperties.AutomationId="SettingsScrollToTopCard">
                            <controls:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE74A;" />
                            </controls:SettingsCard.HeaderIcon>
                            <ToggleSwitch
                                AutomationProperties.AutomationId="SettingsScrollToTopToggle"
                                IsOn="{x:Bind ViewModel.ScrollToTopOnSort, Mode=TwoWay}" />
                        </controls:SettingsCard>

                        <controls:SettingsCard
                            x:Uid="SC_AuthorLiveTiles"
                            AutomationProperties.AutomationId="SettingsAuthorLiveTilesCard">
                            <controls:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE8A9;" />
                            </controls:SettingsCard.HeaderIcon>
                            <ToggleSwitch
                                AutomationProperties.AutomationId="SettingsAuthorLiveTilesToggle"
                                IsOn="{x:Bind ViewModel.AuthorLiveTilesEnabled, Mode=TwoWay}" />
                        </controls:SettingsCard>

                        <!-- Navigation Visibility Section -->
                        <TextBlock
                            x:Uid="Settings_NavigationHeader"
                            Margin="1,28,0,4"
                            Style="{StaticResource BodyStrongTextBlockStyle}" />

                        <controls:SettingsCard
                            x:Uid="SC_Navigation"
                            AutomationProperties.AutomationId="SettingsNavigationCard">
                            <controls:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE700;" />
                            </controls:SettingsCard.HeaderIcon>
                            <StackPanel Orientation="Horizontal" Spacing="24">
                                <CheckBox
                                    x:Uid="Settings_ShowGalleryNav"
                                    IsChecked="{x:Bind ViewModel.ShowGalleryNav, Mode=TwoWay}" />
                                <CheckBox
                                    x:Uid="Settings_ShowCharactersNav"
                                    IsChecked="{x:Bind ViewModel.ShowCharactersNav, Mode=TwoWay}" />
                                <CheckBox
                                    x:Uid="Settings_ShowCoordinatesNav"
                                    IsChecked="{x:Bind ViewModel.ShowCoordinatesNav, Mode=TwoWay}" />
                                <CheckBox
                                    x:Uid="Settings_ShowScreenshotsNav"
                                    IsChecked="{x:Bind ViewModel.ShowScreenshotsNav, Mode=TwoWay}" />
                                <CheckBox
                                    x:Uid="Settings_ShowVideosNav"
                                    IsChecked="{x:Bind ViewModel.ShowVideosNav, Mode=TwoWay}" />
                            </StackPanel>
                        </controls:SettingsCard>

                        <!-- Language Section -->
                        <TextBlock
                            x:Uid="Settings_LanguageHeader"
                            Margin="1,28,0,4"
                            Style="{StaticResource BodyStrongTextBlockStyle}" />

                        <controls:SettingsCard
                            x:Uid="SC_Language"
                            AutomationProperties.AutomationId="SettingsLanguageCard">
                            <controls:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE774;" />
                            </controls:SettingsCard.HeaderIcon>
                            <ComboBox
                                x:Name="LanguageComboBox"
                                AutomationProperties.AutomationId="SettingsLanguageComboBox"
                                MinWidth="200"
                                SelectedValue="{x:Bind ViewModel.SelectedLanguage, Mode=TwoWay}"
                                SelectedValuePath="Tag">
                                <ComboBoxItem x:Uid="Settings_LanguageSystem" Tag="" />
                                <ComboBoxItem Content="English" Tag="en-US" />
                                <ComboBoxItem Content="简体中文" Tag="zh-Hans" />
                                <ComboBoxItem Content="繁體中文" Tag="zh-Hant" />
                            </ComboBox>
                        </controls:SettingsCard>

                        <InfoBar
                            x:Uid="Settings_RestartInfo"
                            Margin="0,4,0,0"
                            IsClosable="False"
                            IsOpen="{x:Bind ViewModel.ShowRestartHint, Mode=OneWay}"
                            Severity="Informational">
                            <InfoBar.ActionButton>
                                <Button x:Uid="Settings_RestartButton" Click="RestartApp_Click" />
                            </InfoBar.ActionButton>
                        </InfoBar>

                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

            <!-- Folders Tab -->
            <PivotItem x:Uid="Settings_TabFolders">
                <ScrollViewer Padding="0,16,0,24">
                    <StackPanel Spacing="8">

                        <!-- Scene Folders -->
                        <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Visibility="{x:Bind ViewModel.ShowGalleryNav, Mode=OneWay}">
                            <Expander.Header>
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Uid="Settings_FoldersHeader" VerticalAlignment="Center" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <InfoBadge Grid.Column="1" Value="{x:Bind ViewModel.FolderPaths.Count, Mode=OneWay}" />
                                </Grid>
                            </Expander.Header>
                            <StackPanel Spacing="12">
                                <TextBlock x:Uid="Settings_FoldersDesc" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <Button Command="{x:Bind ViewModel.AddFolderCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon FontSize="16" Glyph="&#xE8DA;" />
                                        <TextBlock x:Uid="Settings_AddFolder" />
                                    </StackPanel>
                                </Button>
                                <ListView
                                    x:Name="FolderListView"
                                    ItemsSource="{x:Bind ViewModel.FolderPaths, Mode=OneWay}"
                                    SelectionMode="None">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <Grid Padding="8,12" ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <FontIcon VerticalAlignment="Center" FontSize="16" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Glyph="&#xE8B7;" />
                                                <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{x:Bind}" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{x:Bind}" />
                                                <Button x:Uid="Settings_RemoveFolder" Grid.Column="2" VerticalAlignment="Center" CommandParameter="{x:Bind}" Click="RemoveFolder_Click" Style="{StaticResource SubtleButtonStyle}">
                                                    <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                                <TextBlock x:Uid="Settings_NoFolders" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Visibility="{x:Bind ViewModel.HasNoFolders, Mode=OneWay}" />
                            </StackPanel>
                        </Expander>

                        <!-- Character Card Folders -->
                        <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Visibility="{x:Bind ViewModel.ShowCharactersNav, Mode=OneWay}">
                            <Expander.Header>
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Uid="Settings_CharaFoldersHeader" VerticalAlignment="Center" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <InfoBadge Grid.Column="1" Value="{x:Bind ViewModel.CharacterFolderPaths.Count, Mode=OneWay}" />
                                </Grid>
                            </Expander.Header>
                            <StackPanel Spacing="12">
                                <TextBlock x:Uid="Settings_CharaFoldersDesc" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <Button Command="{x:Bind ViewModel.AddCharacterFolderCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon FontSize="16" Glyph="&#xE8DA;" />
                                        <TextBlock x:Uid="Settings_AddFolder" />
                                    </StackPanel>
                                </Button>
                                <ListView
                                    x:Name="CharacterFolderListView"
                                    ItemsSource="{x:Bind ViewModel.CharacterFolderPaths, Mode=OneWay}"
                                    SelectionMode="None">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <Grid Padding="8,12" ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <FontIcon VerticalAlignment="Center" FontSize="16" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Glyph="&#xE8B7;" />
                                                <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{x:Bind}" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{x:Bind}" />
                                                <Button x:Uid="Settings_RemoveFolder" Grid.Column="2" VerticalAlignment="Center" CommandParameter="{x:Bind}" Click="RemoveCharacterFolder_Click" Style="{StaticResource SubtleButtonStyle}">
                                                    <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                                <TextBlock x:Uid="Settings_NoFolders" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Visibility="{x:Bind ViewModel.HasNoCharacterFolders, Mode=OneWay}" />
                            </StackPanel>
                        </Expander>

                        <!-- Coordinate Card Folders -->
                        <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Visibility="{x:Bind ViewModel.ShowCoordinatesNav, Mode=OneWay}">
                            <Expander.Header>
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Uid="Settings_CoordFoldersHeader" VerticalAlignment="Center" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <InfoBadge Grid.Column="1" Value="{x:Bind ViewModel.CoordinateFolderPaths.Count, Mode=OneWay}" />
                                </Grid>
                            </Expander.Header>
                            <StackPanel Spacing="12">
                                <TextBlock x:Uid="Settings_CoordFoldersDesc" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <Button Command="{x:Bind ViewModel.AddCoordinateFolderCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon FontSize="16" Glyph="&#xE8DA;" />
                                        <TextBlock x:Uid="Settings_AddFolder" />
                                    </StackPanel>
                                </Button>
                                <ListView
                                    x:Name="CoordinateFolderListView"
                                    ItemsSource="{x:Bind ViewModel.CoordinateFolderPaths, Mode=OneWay}"
                                    SelectionMode="None">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <Grid Padding="8,12" ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <FontIcon VerticalAlignment="Center" FontSize="16" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Glyph="&#xE8B7;" />
                                                <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{x:Bind}" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{x:Bind}" />
                                                <Button x:Uid="Settings_RemoveFolder" Grid.Column="2" VerticalAlignment="Center" CommandParameter="{x:Bind}" Click="RemoveCoordinateFolder_Click" Style="{StaticResource SubtleButtonStyle}">
                                                    <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                                <TextBlock x:Uid="Settings_NoFolders" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Visibility="{x:Bind ViewModel.HasNoCoordinateFolders, Mode=OneWay}" />
                            </StackPanel>
                        </Expander>

                        <!-- Screenshot Folders -->
                        <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Visibility="{x:Bind ViewModel.ShowScreenshotsNav, Mode=OneWay}">
                            <Expander.Header>
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Uid="Settings_ScreenshotFoldersHeader" VerticalAlignment="Center" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <InfoBadge Grid.Column="1" Value="{x:Bind ViewModel.ScreenshotFolderPaths.Count, Mode=OneWay}" />
                                </Grid>
                            </Expander.Header>
                            <StackPanel Spacing="12">
                                <TextBlock x:Uid="Settings_ScreenshotFoldersDesc" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <Button Command="{x:Bind ViewModel.AddScreenshotFolderCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon FontSize="16" Glyph="&#xE8DA;" />
                                        <TextBlock x:Uid="Settings_AddFolder" />
                                    </StackPanel>
                                </Button>
                                <ListView
                                    x:Name="ScreenshotFolderListView"
                                    ItemsSource="{x:Bind ViewModel.ScreenshotFolderPaths, Mode=OneWay}"
                                    SelectionMode="None">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <Grid Padding="8,12" ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <FontIcon VerticalAlignment="Center" FontSize="16" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Glyph="&#xE8B7;" />
                                                <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{x:Bind}" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{x:Bind}" />
                                                <Button x:Uid="Settings_RemoveFolder" Grid.Column="2" VerticalAlignment="Center" CommandParameter="{x:Bind}" Click="RemoveScreenshotFolder_Click" Style="{StaticResource SubtleButtonStyle}">
                                                    <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                                <TextBlock x:Uid="Settings_NoFolders" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Visibility="{x:Bind ViewModel.HasNoScreenshotFolders, Mode=OneWay}" />
                            </StackPanel>
                        </Expander>

                        <!-- Video Folders -->
                        <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Visibility="{x:Bind ViewModel.ShowVideosNav, Mode=OneWay}">
                            <Expander.Header>
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Uid="Settings_VideoFoldersHeader" VerticalAlignment="Center" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <InfoBadge Grid.Column="1" Value="{x:Bind ViewModel.VideoFolderPaths.Count, Mode=OneWay}" />
                                </Grid>
                            </Expander.Header>
                            <StackPanel Spacing="12">
                                <TextBlock x:Uid="Settings_VideoFoldersDesc" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <Button Command="{x:Bind ViewModel.AddVideoFolderCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon FontSize="16" Glyph="&#xE8DA;" />
                                        <TextBlock x:Uid="Settings_AddFolder" />
                                    </StackPanel>
                                </Button>
                                <ListView
                                    x:Name="VideoFolderListView"
                                    ItemsSource="{x:Bind ViewModel.VideoFolderPaths, Mode=OneWay}"
                                    SelectionMode="None">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <Grid Padding="8,12" ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <FontIcon VerticalAlignment="Center" FontSize="16" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Glyph="&#xE8B7;" />
                                                <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{x:Bind}" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{x:Bind}" />
                                                <Button x:Uid="Settings_RemoveFolder" Grid.Column="2" VerticalAlignment="Center" CommandParameter="{x:Bind}" Click="RemoveVideoFolder_Click" Style="{StaticResource SubtleButtonStyle}">
                                                    <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                                <TextBlock x:Uid="Settings_NoFolders" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Visibility="{x:Bind ViewModel.HasNoVideoFolders, Mode=OneWay}" />
                            </StackPanel>
                        </Expander>

                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

            <!-- Filters Tab -->
            <PivotItem x:Uid="Settings_TabFilters">
                <ScrollViewer Padding="0,16,0,24">
                    <StackPanel Spacing="8">

                        <!-- Scene Resolution Filter -->
                        <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                            <Expander.Header>
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Uid="Settings_ResolutionHeader" VerticalAlignment="Center" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.ResolutionFilterEnabled, Mode=TwoWay}" OnContent="" OffContent="" MinWidth="0" Margin="0,-4,0,-4" />
                                </Grid>
                            </Expander.Header>
                            <StackPanel Spacing="12">
                                <TextBlock x:Uid="Settings_ResolutionDesc" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <Grid ColumnSpacing="8" Visibility="{x:Bind ViewModel.ResolutionFilterEnabled, Mode=OneWay}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" MaxWidth="240" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="ResolutionInput" x:Uid="Settings_ResolutionInput" KeyDown="ResolutionInput_KeyDown" />
                                    <Button Grid.Column="1" Click="AddResolution_Click" Style="{StaticResource AccentButtonStyle}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontSize="14" Glyph="&#xE710;" />
                                            <TextBlock x:Uid="Settings_AddResolution" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                                <ListView
                                    x:Name="ResolutionListView"
                                    ItemsSource="{x:Bind ViewModel.AllowedResolutions, Mode=OneWay}"
                                    SelectionMode="None"
                                    Visibility="{x:Bind ViewModel.ResolutionFilterEnabled, Mode=OneWay}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <Grid Padding="8,8" ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <FontIcon VerticalAlignment="Center" FontSize="16" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Glyph="&#xE740;" />
                                                <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{x:Bind}" />
                                                <Button x:Uid="Settings_RemoveResolution" Grid.Column="2" VerticalAlignment="Center" CommandParameter="{x:Bind}" Click="RemoveResolution_Click" Style="{StaticResource SubtleButtonStyle}">
                                                    <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </Expander>

                        <!-- Character Resolution Filter -->
                        <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                            <Expander.Header>
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Uid="Settings_CharaResolutionHeader" VerticalAlignment="Center" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.CharacterResolutionFilterEnabled, Mode=TwoWay}" OnContent="" OffContent="" MinWidth="0" Margin="0,-4,0,-4" />
                                </Grid>
                            </Expander.Header>
                            <StackPanel Spacing="12">
                                <TextBlock x:Uid="Settings_CharaResolutionDesc" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <Grid ColumnSpacing="8" Visibility="{x:Bind ViewModel.CharacterResolutionFilterEnabled, Mode=OneWay}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" MaxWidth="240" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="CharacterResolutionInput" x:Uid="Settings_CharaResolutionInput" KeyDown="CharacterResolutionInput_KeyDown" />
                                    <Button Grid.Column="1" Click="AddCharacterResolution_Click" Style="{StaticResource AccentButtonStyle}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontSize="14" Glyph="&#xE710;" />
                                            <TextBlock x:Uid="Settings_AddCharaResolution" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                                <ListView
                                    x:Name="CharacterResolutionListView"
                                    ItemsSource="{x:Bind ViewModel.CharacterAllowedResolutions, Mode=OneWay}"
                                    SelectionMode="None"
                                    Visibility="{x:Bind ViewModel.CharacterResolutionFilterEnabled, Mode=OneWay}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <Grid Padding="8,8" ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <FontIcon VerticalAlignment="Center" FontSize="16" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Glyph="&#xE740;" />
                                                <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{x:Bind}" />
                                                <Button x:Uid="Settings_RemoveCharaResolution" Grid.Column="2" VerticalAlignment="Center" CommandParameter="{x:Bind}" Click="RemoveCharacterResolution_Click" Style="{StaticResource SubtleButtonStyle}">
                                                    <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </Expander>

                        <!-- Coordinate Resolution Filter -->
                        <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                            <Expander.Header>
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Uid="Settings_CoordResolutionHeader" VerticalAlignment="Center" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.CoordinateResolutionFilterEnabled, Mode=TwoWay}" OnContent="" OffContent="" MinWidth="0" Margin="0,-4,0,-4" />
                                </Grid>
                            </Expander.Header>
                            <StackPanel Spacing="12">
                                <TextBlock x:Uid="Settings_CoordResolutionDesc" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <Grid ColumnSpacing="8" Visibility="{x:Bind ViewModel.CoordinateResolutionFilterEnabled, Mode=OneWay}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" MaxWidth="240" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="CoordinateResolutionInput" x:Uid="Settings_CoordResolutionInput" KeyDown="CoordinateResolutionInput_KeyDown" />
                                    <Button Grid.Column="1" Click="AddCoordinateResolution_Click" Style="{StaticResource AccentButtonStyle}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontSize="14" Glyph="&#xE710;" />
                                            <TextBlock x:Uid="Settings_AddCoordResolution" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                                <ListView
                                    x:Name="CoordinateResolutionListView"
                                    ItemsSource="{x:Bind ViewModel.CoordinateAllowedResolutions, Mode=OneWay}"
                                    SelectionMode="None"
                                    Visibility="{x:Bind ViewModel.CoordinateResolutionFilterEnabled, Mode=OneWay}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <Grid Padding="8,8" ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <FontIcon VerticalAlignment="Center" FontSize="16" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Glyph="&#xE740;" />
                                                <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{x:Bind}" />
                                                <Button x:Uid="Settings_RemoveCoordResolution" Grid.Column="2" VerticalAlignment="Center" CommandParameter="{x:Bind}" Click="RemoveCoordinateResolution_Click" Style="{StaticResource SubtleButtonStyle}">
                                                    <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </Expander>

                        <!-- Plugin Analysis -->
                        <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                            <Expander.Header>
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Uid="Settings_PluginHeader" VerticalAlignment="Center" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.PluginAnalysisEnabled, Mode=TwoWay}" OnContent="" OffContent="" MinWidth="0" Margin="0,-4,0,-4" />
                                </Grid>
                            </Expander.Header>
                            <StackPanel Spacing="12">
                                <TextBlock x:Uid="Settings_PluginDesc" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <StackPanel Spacing="12" Visibility="{x:Bind ViewModel.PluginAnalysisEnabled, Mode=OneWay}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button
                                            Command="{x:Bind ViewModel.ScanMissingMetadataCommand}"
                                            IsEnabled="{x:Bind GalleryViewModel.IsNotParsingMetadata, Mode=OneWay}">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon FontSize="14" Glyph="&#xE895;" />
                                                <TextBlock x:Uid="Settings_ScanMissing" />
                                            </StackPanel>
                                        </Button>
                                        <Button
                                            Command="{x:Bind ViewModel.RescanMetadataCommand}"
                                            IsEnabled="{x:Bind GalleryViewModel.IsNotParsingMetadata, Mode=OneWay}">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon FontSize="14" Glyph="&#xE72C;" />
                                                <TextBlock x:Uid="Settings_RescanAll" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                    <StackPanel
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        VerticalAlignment="Center"
                                        Visibility="{x:Bind GalleryViewModel.IsParsingMetadata, Mode=OneWay}">
                                        <ProgressRing Width="16" Height="16" IsActive="True" />
                                        <TextBlock x:Uid="Settings_ScanProgress" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind GalleryViewModel.PendingMetadataCount, Mode=OneWay}" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Expander>

                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

            <!-- Advanced Tab -->
            <PivotItem x:Uid="Settings_TabAdvanced">
                <ScrollViewer Padding="0,16,0,24">
                    <StackPanel Spacing="4">

                        <!-- Cache Section -->
                        <TextBlock
                            x:Uid="Settings_CacheHeader"
                            Margin="1,0,0,4"
                            Style="{StaticResource BodyStrongTextBlockStyle}" />

                        <controls:SettingsCard
                            x:Uid="SC_CacheFolder"
                            AutomationProperties.AutomationId="SettingsCacheFolderCard">
                            <controls:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE8B7;" />
                            </controls:SettingsCard.HeaderIcon>
                            <TextBlock
                                MaxWidth="400"
                                IsTextSelectionEnabled="True"
                                Text="{x:Bind ViewModel.CacheFolderDisplay, Mode=OneWay}"
                                TextTrimming="CharacterEllipsis"
                                TextWrapping="NoWrap"
                                ToolTipService.ToolTip="{x:Bind ViewModel.CacheFolderDisplay, Mode=OneWay}" />
                        </controls:SettingsCard>

                        <controls:SettingsCard
                            x:Uid="SC_CacheActions"
                            AutomationProperties.AutomationId="SettingsCacheActionsCard">
                            <controls:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE90F;" />
                            </controls:SettingsCard.HeaderIcon>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Command="{x:Bind ViewModel.ChangeCacheFolderCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon FontSize="14" Glyph="&#xE8DA;" />
                                        <TextBlock x:Uid="Settings_ChangeFolder" />
                                    </StackPanel>
                                </Button>
                                <Button Command="{x:Bind ViewModel.ResetCacheFolderCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon FontSize="14" Glyph="&#xE777;" />
                                        <TextBlock x:Uid="Settings_ResetDefault" />
                                    </StackPanel>
                                </Button>
                                <Button Click="ClearCache_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                        <TextBlock x:Uid="Settings_ClearCache" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </controls:SettingsCard>

                        <!-- Cache Buffer Section -->
                        <TextBlock
                            x:Uid="Settings_AdvancedHeader"
                            Margin="1,28,0,4"
                            Style="{StaticResource BodyStrongTextBlockStyle}" />

                        <controls:SettingsCard
                            x:Uid="SC_CacheBuffer"
                            AutomationProperties.AutomationId="SettingsCacheBufferCard">
                            <controls:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE7F8;" />
                            </controls:SettingsCard.HeaderIcon>
                            <NumberBox
                                AutomationProperties.AutomationId="SettingsCacheBufferNumberBox"
                                MinWidth="160"
                                LargeChange="4"
                                Maximum="40"
                                Minimum="2"
                                SmallChange="2"
                                SpinButtonPlacementMode="Inline"
                                Value="{x:Bind ViewModel.CacheLength, Mode=TwoWay}" />
                        </controls:SettingsCard>

                        <InfoBar
                            x:Uid="Settings_CacheBufferWarning"
                            Margin="0,4,0,0"
                            IsClosable="False"
                            IsOpen="True"
                            Severity="Warning" />

                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

            <!-- Plugins Tab -->
            <PivotItem x:Uid="Settings_TabPlugins">
                <ScrollViewer Padding="0,16,0,24">
                    <StackPanel Spacing="32">

                        <!-- Overview -->
                        <StackPanel Spacing="16">
                            <TextBlock
                                x:Uid="Plugins_Header"
                                Style="{StaticResource SubtitleTextBlockStyle}" />
                            <TextBlock
                                x:Uid="Plugins_Desc"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextWrapping="Wrap" />
                            <InfoBar
                                x:Uid="Plugins_RiskWarning"
                                IsOpen="True"
                                IsClosable="False"
                                Severity="Warning" />
                        </StackPanel>

                        <!-- Install Instructions -->
                        <StackPanel Spacing="8">
                            <TextBlock
                                x:Uid="Plugins_InstallHeader"
                                Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock
                                x:Uid="Plugins_InstallStepDownload"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextWrapping="Wrap" />
                            <TextBlock
                                x:Uid="Plugins_InstallStepCopy"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextWrapping="Wrap" />
                            <TextBlock
                                x:Uid="Plugins_InstallStepRestart"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextWrapping="Wrap" />
                        </StackPanel>

                        <!-- Installed Plugins -->
                        <StackPanel Spacing="16">
                            <TextBlock
                                x:Uid="Plugins_RestartNote"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                            <TextBlock
                                x:Uid="Plugins_Empty"
                                Opacity="0.6"
                                Visibility="{x:Bind HasNoPlugins}" />

                            <ItemsControl ItemsSource="{x:Bind PluginItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="local:PluginListItem">
                                        <Button
                                            Margin="0,0,0,8"
                                            Padding="0"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Click="PluginItem_Click"
                                            CommandParameter="{x:Bind}">
                                            <Grid
                                                Padding="16,12"
                                                ColumnSpacing="12"
                                                CornerRadius="{StaticResource OverlayCornerRadius}"
                                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                BorderThickness="1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <FontIcon
                                                    VerticalAlignment="Center"
                                                    Glyph="&#xEA86;" />

                                                <StackPanel Grid.Column="1" Spacing="2">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock
                                                            Style="{StaticResource BodyStrongTextBlockStyle}"
                                                            Text="{x:Bind Name}" />
                                                        <TextBlock
                                                            VerticalAlignment="Center"
                                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                            Style="{StaticResource CaptionTextBlockStyle}"
                                                            Text="{x:Bind Version}"
                                                            Visibility="{x:Bind HasVersion}" />
                                                    </StackPanel>
                                                    <TextBlock
                                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                        Style="{StaticResource CaptionTextBlockStyle}"
                                                        Text="{x:Bind Description}"
                                                        TextWrapping="Wrap"
                                                        Visibility="{x:Bind HasDescription}" />
                                                    <TextBlock
                                                        Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                                        Style="{StaticResource CaptionTextBlockStyle}"
                                                        Text="{x:Bind Error}"
                                                        TextWrapping="Wrap"
                                                        Visibility="{x:Bind HasError}" />
                                                    <TextBlock
                                                        Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                                        Style="{StaticResource CaptionTextBlockStyle}"
                                                        Text="{x:Bind UpdateText}"
                                                        Visibility="{x:Bind UpdateAvailable}" />
                                                </StackPanel>

                                                <TextBlock
                                                    Grid.Column="2"
                                                    VerticalAlignment="Center"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Style="{StaticResource CaptionTextBlockStyle}"
                                                    Text="{x:Bind StatusText}" />

                                                <FontIcon
                                                    Grid.Column="3"
                                                    VerticalAlignment="Center"
                                                    FontSize="12"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Glyph="&#xE76C;" />
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Button Click="OpenPluginsFolder_Click">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon FontSize="14" Glyph="&#xE8DA;" />
                                    <TextBlock x:Uid="Plugins_OpenFolder" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

            <!-- OCD Tab -->
            <PivotItem x:Uid="Settings_TabOcd">
                <ScrollViewer Padding="0,16,0,24">
                    <StackPanel Spacing="4">

                        <InfoBar
                            x:Uid="Settings_OcdDesc"
                            Margin="0,0,0,12"
                            IsOpen="True"
                            IsClosable="False"
                            Severity="Warning" />

                        <controls:SettingsCard
                            x:Uid="SC_SizeSelector"
                            AutomationProperties.AutomationId="SettingsSizeSelectorCard">
                            <controls:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE799;" />
                            </controls:SettingsCard.HeaderIcon>
                            <ToggleSwitch
                                AutomationProperties.AutomationId="SettingsSizeSelectorToggle"
                                IsOn="{x:Bind ViewModel.SizeSelectorEnabled, Mode=TwoWay}" />
                        </controls:SettingsCard>

                        <controls:SettingsCard
                            x:Uid="SC_VisualSimilarity"
                            AutomationProperties.AutomationId="SettingsVisualSimilarityCard">
                            <controls:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE8FD;" />
                            </controls:SettingsCard.HeaderIcon>
                            <ToggleSwitch
                                AutomationProperties.AutomationId="SettingsVisualSimilarityToggle"
                                IsOn="{x:Bind ViewModel.UseVisualSimilarity, Mode=TwoWay}" />
                        </controls:SettingsCard>

                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

        </Pivot>
    </Grid>
</Page>
