<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="KoikatsuSceneGallery.Pages.PostDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:KoikatsuSceneGallery.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:KoikatsuSceneGallery.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:KoikatsuSceneGallery.ViewModels"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,16">
        <StackPanel MaxWidth="800" Spacing="16">

            <!-- Header -->
            <Grid RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button
                            x:Uid="Detail_GoBack"
                            VerticalAlignment="Center"
                            Click="GoBack_Click"
                            Style="{StaticResource SubtleButtonStyle}">
                            <FontIcon FontSize="14" Glyph="&#xE72B;" />
                        </Button>
                        <TextBlock
                            x:Name="TitleText"
                            VerticalAlignment="Center"
                            Style="{StaticResource TitleTextBlockStyle}"
                            Text="{x:Bind ViewModel.DisplayTitle, Mode=OneWay}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{x:Bind ViewModel.ArtworkIdText, Mode=OneWay}" />
                </StackPanel>

                <StackPanel
                    Grid.Row="1"
                    HorizontalAlignment="Left"
                    Orientation="Horizontal"
                    Spacing="8">
                    <Button
                        x:Uid="PostDetail_OpenInBrowser"
                        Click="OpenInBrowser_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="14" Glyph="&#xE774;" />
                            <TextBlock x:Uid="PostDetail_OpenInBrowserLabel" />
                        </StackPanel>
                    </Button>
                    <Button
                        x:Name="SaveButton"
                        x:Uid="PostDetail_Save"
                        Click="Save_Click"
                        IsEnabled="{x:Bind ViewModel.CanSave, Mode=OneWay}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="14" Glyph="&#xE74E;" />
                            <TextBlock x:Uid="PostDetail_SaveLabel" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Loading indicator -->
            <StackPanel
                HorizontalAlignment="Center"
                Orientation="Horizontal"
                Spacing="8"
                Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}">
                <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" Width="20" Height="20" />
                <TextBlock
                    x:Uid="PostDetail_Loading"
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- Local images -->
            <StackPanel
                x:Name="LocalImagesPanel"
                Spacing="8"
                Visibility="{x:Bind ViewModel.HasLocalImages, Mode=OneWay}">
                <GridView
                    ItemsSource="{x:Bind ViewModel.LocalImages, Mode=OneWay}"
                    CanDragItems="True"
                    DragItemsStarting="LocalImagesGrid_DragItemsStarting"
                    IsItemClickEnabled="True"
                    ItemClick="LocalImage_ItemClick"
                    SelectionMode="None">
                    <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="4" />
                        </ItemsPanelTemplate>
                    </GridView.ItemsPanel>
                    <GridView.ItemContainerStyle>
                        <Style TargetType="GridViewItem">
                            <Setter Property="Margin" Value="0,0,8,8" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="MinWidth" Value="0" />
                            <Setter Property="MinHeight" Value="0" />
                        </Style>
                    </GridView.ItemContainerStyle>
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:LocalImagePreview">
                            <Grid
                                Width="160"
                                Height="120"
                                ToolTipService.ToolTip="{x:Bind FileName}">
                                <Border
                                    CornerRadius="6"
                                    Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                    <Image Stretch="Uniform">
                                        <Image.Source>
                                            <BitmapImage
                                                DecodePixelWidth="240"
                                                UriSource="{x:Bind ImageUri}" />
                                        </Image.Source>
                                    </Image>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </StackPanel>

            <!-- Rating badge -->
            <StackPanel
                x:Name="RatingPanel"
                Orientation="Horizontal"
                Spacing="8"
                Visibility="{x:Bind ViewModel.ShowRating, Mode=OneWay}">
                <Border
                    Padding="8,4"
                    CornerRadius="4"
                    Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}">
                    <TextBlock
                        Text="{x:Bind ViewModel.RatingText, Mode=OneWay}"
                        Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        FontWeight="SemiBold" />
                </Border>
            </StackPanel>

            <!-- Tags -->
            <StackPanel
                x:Name="TagsPanel"
                Spacing="8"
                Visibility="{x:Bind ViewModel.HasTags, Mode=OneWay}">
                <TextBlock
                    x:Uid="PostDetail_TagsHeader"
                    Style="{StaticResource SubtitleTextBlockStyle}" />
                <ItemsControl ItemsSource="{x:Bind ViewModel.Tags, Mode=OneWay}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <controls:WrapPanel Spacing="4" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="local:TagDisplay">
                            <Border
                                Padding="8,4"
                                CornerRadius="4"
                                Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                <TextBlock
                                    Text="{x:Bind Display}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    IsTextSelectionEnabled="True"
                                    TextWrapping="NoWrap" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Description -->
            <StackPanel
                x:Name="DescriptionPanel"
                Spacing="8"
                Visibility="{x:Bind ViewModel.HasDescription, Mode=OneWay}">
                <TextBlock
                    x:Uid="PostDetail_DescriptionHeader"
                    Style="{StaticResource SubtitleTextBlockStyle}" />
                <RichTextBlock
                    x:Name="DescriptionText"
                    IsTextSelectionEnabled="True"
                    TextWrapping="Wrap" />
            </StackPanel>

            <!-- Local file info -->
            <StackPanel Spacing="4">
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="{x:Bind ViewModel.LocalFileInfo, Mode=OneWay}" />
                <TextBlock
                    x:Name="SavedIndicator"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="{x:Bind ViewModel.SavedStatusText, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.IsDetailLoaded, Mode=OneWay}" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
