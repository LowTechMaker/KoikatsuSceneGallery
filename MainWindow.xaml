<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="KoikatsuSceneGallery.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:KoikatsuSceneGallery"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Koikatsu Scene Gallery"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar
            x:Name="AppTitleBar"
            Title="Koikatsu Scene Gallery"
            BackRequested="TitleBar_BackRequested"
            IsBackButtonVisible="{x:Bind NavFrame.CanGoBack, Mode=OneWay}"
            IsPaneToggleButtonVisible="True"
            PaneToggleRequested="TitleBar_PaneToggleRequested">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <NavigationView
            x:Name="NavView"
            AutomationProperties.AutomationId="NavView"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="False"
            IsSettingsVisible="True"
            SelectionChanged="NavView_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem
                    x:Name="LibraryNavItem"
                    x:Uid="Nav_Library"
                    AutomationProperties.AutomationId="LibraryNavItem"
                    IsSelected="True"
                    Tag="library"
                    ToolTipService.ToolTip="{x:Null}">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8B9;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    x:Name="ScreenshotsNavItem"
                    x:Uid="Nav_Screenshots"
                    AutomationProperties.AutomationId="ScreenshotsNavItem"
                    Tag="screenshots"
                    ToolTipService.ToolTip="{x:Null}">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE722;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    x:Name="VideosNavItem"
                    x:Uid="Nav_Videos"
                    AutomationProperties.AutomationId="VideosNavItem"
                    Tag="videos"
                    ToolTipService.ToolTip="{x:Null}">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE714;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <!--  Shown only when an author plugin is installed (see ctor).  -->
                <NavigationViewItem
                    x:Name="AuthorsNavItem"
                    x:Uid="Nav_Authors"
                    AutomationProperties.AutomationId="AuthorsNavItem"
                    Tag="authors"
                    ToolTipService.ToolTip="{x:Null}"
                    Visibility="Collapsed">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE716;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <NavigationView.FooterMenuItems>
                <!--  Shown only when an import provider plugin is installed (see ctor).  -->
                <NavigationViewItem
                    x:Name="ImportNavItem"
                    x:Uid="Nav_Import"
                    AutomationProperties.AutomationId="ImportNavItem"
                    Tag="import"
                    ToolTipService.ToolTip="{x:Null}"
                    Visibility="Collapsed">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE896;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <SelectorBar
                    x:Name="LibrarySelectorBar"
                    AutomationProperties.AutomationId="LibrarySelectorBar"
                    Margin="20,8,20,0"
                    HorizontalAlignment="Left"
                    SelectionChanged="LibrarySelectorBar_SelectionChanged">
                    <SelectorBarItem
                        x:Name="ScenesSelectorItem"
                        x:Uid="Library_Scenes"
                        AutomationProperties.AutomationId="LibraryScenesSelectorItem"
                        IsSelected="True" />
                    <SelectorBarItem
                        x:Name="CharactersSelectorItem"
                        x:Uid="Library_Characters"
                        AutomationProperties.AutomationId="LibraryCharactersSelectorItem" />
                    <SelectorBarItem
                        x:Name="CoordinatesSelectorItem"
                        x:Uid="Library_Coordinates"
                        AutomationProperties.AutomationId="LibraryCoordinatesSelectorItem" />
                </SelectorBar>

                <Frame
                    x:Name="NavFrame"
                    AutomationProperties.AutomationId="NavFrame"
                    Grid.Row="1"
                    Navigated="NavFrame_Navigated" />
            </Grid>
        </NavigationView>
    </Grid>
</Window>
