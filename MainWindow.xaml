<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="KoikatsuSceneGallery.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:KoikatsuSceneGallery"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Koikatsu Scene Gallery"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar
            x:Name="AppTitleBar"
            Title="Koikatsu Scene Gallery"
            BackRequested="TitleBar_BackRequested"
            IsBackButtonVisible="{x:Bind NavFrame.CanGoBack, Mode=OneWay}"
            IsPaneToggleButtonVisible="True"
            PaneToggleRequested="TitleBar_PaneToggleRequested">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <NavigationView
            x:Name="NavView"
            AutomationProperties.AutomationId="NavView"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="False"
            IsSettingsVisible="True"
            SelectionChanged="NavView_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem
                    x:Name="GalleryNavItem"
                    x:Uid="Nav_Gallery"
                    AutomationProperties.AutomationId="GalleryNavItem"
                    IsSelected="True"
                    Tag="gallery">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8B9;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    x:Name="CharactersNavItem"
                    x:Uid="Nav_Characters"
                    AutomationProperties.AutomationId="CharactersNavItem"
                    Tag="characters">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE77B;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    x:Name="CoordinatesNavItem"
                    x:Uid="Nav_Coordinates"
                    AutomationProperties.AutomationId="CoordinatesNavItem"
                    Tag="coordinates">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE78A;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    x:Name="ScreenshotsNavItem"
                    x:Uid="Nav_Screenshots"
                    AutomationProperties.AutomationId="ScreenshotsNavItem"
                    Tag="screenshots">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE722;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    x:Name="VideosNavItem"
                    x:Uid="Nav_Videos"
                    AutomationProperties.AutomationId="VideosNavItem"
                    Tag="videos">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE714;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <!--  Shown only when an author plugin is installed (see ctor).  -->
                <NavigationViewItem
                    x:Name="AuthorsNavItem"
                    x:Uid="Nav_Authors"
                    AutomationProperties.AutomationId="AuthorsNavItem"
                    Tag="authors"
                    Visibility="Collapsed">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE716;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <NavigationView.FooterMenuItems>
                <!--  Shown only when an import provider plugin is installed (see ctor).  -->
                <NavigationViewItem
                    x:Name="ImportNavItem"
                    x:Uid="Nav_Import"
                    AutomationProperties.AutomationId="ImportNavItem"
                    Tag="import"
                    Visibility="Collapsed">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE896;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>
            <Frame x:Name="NavFrame" AutomationProperties.AutomationId="NavFrame" />
        </NavigationView>
    </Grid>
</Window>
