<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="KoikatsuSceneGallery.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:KoikatsuSceneGallery">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Default">
                    <SolidColorBrush x:Key="RatingR18GBadgeBrush" Color="#C62828" />
                    <SolidColorBrush x:Key="RatingR18BadgeBrush" Color="#D84315" />
                    <SolidColorBrush x:Key="RatingAllAgesBadgeBrush" Color="#2E7D32" />
                    <SolidColorBrush x:Key="RatingBadgeForegroundBrush" Color="White" />
                    <SolidColorBrush x:Key="LiveTileOverlayForegroundBrush" Color="White" />
                    <SolidColorBrush x:Key="LiveTileOverlaySecondaryBrush" Color="#CCFFFFFF" />
                    <Color x:Key="LiveTileScrimEndColor">#CC000000</Color>
                    <SolidColorBrush x:Key="VideoPlayIconForegroundBrush" Color="White" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="RatingR18GBadgeBrush" Color="#C62828" />
                    <SolidColorBrush x:Key="RatingR18BadgeBrush" Color="#D84315" />
                    <SolidColorBrush x:Key="RatingAllAgesBadgeBrush" Color="#2E7D32" />
                    <SolidColorBrush x:Key="RatingBadgeForegroundBrush" Color="White" />
                    <SolidColorBrush x:Key="LiveTileOverlayForegroundBrush" Color="White" />
                    <SolidColorBrush x:Key="LiveTileOverlaySecondaryBrush" Color="#CCFFFFFF" />
                    <Color x:Key="LiveTileScrimEndColor">#CC000000</Color>
                    <SolidColorBrush x:Key="VideoPlayIconForegroundBrush" Color="White" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="HighContrast">
                    <SolidColorBrush x:Key="RatingR18GBadgeBrush" Color="{ThemeResource SystemColorHighlightColor}" />
                    <SolidColorBrush x:Key="RatingR18BadgeBrush" Color="{ThemeResource SystemColorHighlightColor}" />
                    <SolidColorBrush x:Key="RatingAllAgesBadgeBrush" Color="{ThemeResource SystemColorHighlightColor}" />
                    <SolidColorBrush x:Key="RatingBadgeForegroundBrush" Color="{ThemeResource SystemColorHighlightTextColor}" />
                    <SolidColorBrush x:Key="LiveTileOverlayForegroundBrush" Color="{ThemeResource SystemColorHighlightTextColor}" />
                    <SolidColorBrush x:Key="LiveTileOverlaySecondaryBrush" Color="{ThemeResource SystemColorHighlightTextColor}" />
                    <Color x:Key="LiveTileScrimEndColor">#CC000000</Color>
                    <SolidColorBrush x:Key="VideoPlayIconForegroundBrush" Color="{ThemeResource SystemColorHighlightTextColor}" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
