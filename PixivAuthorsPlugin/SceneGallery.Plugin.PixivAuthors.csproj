<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>SceneGallery.Plugin.PixivAuthors</RootNamespace>
    <!-- Produces a deps.json and copy-local dependencies so the app's
         AssemblyDependencyResolver can resolve this plugin's references. -->
    <EnableDynamicLoading>true</EnableDynamicLoading>
  </PropertyGroup>

  <ItemGroup>
    <!--
      The contracts assembly must NOT be copied into the plugin's output:
      the app loads SceneGallery.PluginSdk.dll in the default load context,
      and a second copy beside the plugin would be loaded into the plugin's
      AssemblyLoadContext, breaking type identity (casts to IPlugin fail).
    -->
    <ProjectReference Include="..\PluginSdk\SceneGallery.PluginSdk.csproj">
      <Private>false</Private>
      <ExcludeAssets>runtime</ExcludeAssets>
    </ProjectReference>
  </ItemGroup>
</Project>
